# ═══════════════════════════════════════════════════════════════════════════════
# Discord Manga Scanlation Bot — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your real .env to GitHub!
# ═══════════════════════════════════════════════════════════════════════════════

# ── REQUIRED ──────────────────────────────────────────────────────────────────

# Your Discord bot token (from https://discord.com/developers/applications)
# Bot → Reset Token → Copy
DISCORD_TOKEN=your_discord_bot_token_here

# Your Discord user ID(s) — right-click your username → Copy ID (comma-separated)
OWNER_IDS=123456789012345678

# ── GOOGLE API (Highly Recommended) ──────────────────────────────────────────
#
# ONE key unlocks ALL of these features:
#   ✅ Gemini Vision OCR  — primary OCR for /scan_manga, /detect_text
#   ✅ Gemini Translation — primary translation for all /translate_* commands
#   ✅ Nano Banana Image Gen — /generate_image, /edit_image (NEW!)
#
# HOW TO GET YOUR KEY (free, 2 minutes):
#   1. Go to https://aistudio.google.com/apikey
#   2. Sign in with your Google account
#   3. Click "Create API Key"
#   4. Copy the key (starts with "AIza...")
#   5. Paste it below
#
# Free tier limits:
#   • Gemini 2.5 Flash: 1,500 requests/day, 1M tokens/min
#   • Image generation: 1,500 requests/day
#   • Vision OCR: 1,500 requests/day
#
GOOGLE_API_KEY=AIzaSy_your_key_from_aistudio_google_com

# ── OPTIONAL ──────────────────────────────────────────────────────────────────

# OpenAI API key — fallback translation if Gemini unavailable
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Discord channel ID for audit logs (right-click channel → Copy ID)
LOG_CHANNEL_ID=

# Test guild ID — slash commands sync instantly here during development
# (Global sync takes up to 1 hour; guild sync is instant)
TEST_GUILD_ID=

# ── NANO BANANA MODELS AVAILABLE WITH YOUR GOOGLE_API_KEY ────────────────────
# models/gemini-2.5-flash-image  → "Nano Banana"      (fast, creative)
# models/gemini-3.1-flash-image  → "Nano Banana 2"    (enhanced quality)
# models/nano-banana-pro-preview → "Nano Banana Pro"  (highest quality)
# models/imagen-4.0-generate-001 → "Imagen 4"         (photorealistic)
