# MangaFlow AI — Environment Variables
# Copy this file to .env and fill in your values

# App
APP_NAME=MangaFlow AI
DEBUG=false
ENVIRONMENT=production
SECRET_KEY=your-secret-key-here-use-openssl-rand-hex-32
ALLOWED_ORIGINS=["http://localhost:3000","https://yourdomain.com"]

# Database
DATABASE_URL=postgresql+asyncpg://mangaflow:password@localhost:5432/mangaflow

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Auth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Cloudflare R2 Storage
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=mangaflow-uploads
R2_PUBLIC_URL=https://cdn.yourdomain.com

# AI APIs
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-pro
DEFAULT_AI_PROVIDER=openai

# Processing
MAX_UPLOAD_SIZE_BYTES=2147483648
MAX_CONCURRENT_JOBS=4
FREE_PAGES_PER_DAY=20
AUTO_DELETE_AFTER_DAYS=30

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@mangaflow.ai

# Monitoring
LOG_LEVEL=INFO
