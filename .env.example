# ════════════════════════════════════════════════════════════════════
#  Discord Manga Scanlation Bot — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git!
# ════════════════════════════════════════════════════════════════════

# ── REQUIRED ─────────────────────────────────────────────────────────
# Your bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Comma-separated Discord user IDs of bot owners (get yours from @userinfobot)
OWNER_IDS=123456789,987654321

# ── OPTIONAL — AI / Translation ──────────────────────────────────────
# OpenAI API key for GPT-powered translation fallback
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_key_here

# DeepL API key for high-quality translation (optional)
# Get one at https://www.deepl.com/pro-api
DEEPL_API_KEY=your_deepl_key_here

# ── OPTIONAL — Discord Settings ───────────────────────────────────────
# Channel ID for audit log messages (leave blank to disable)
LOG_CHANNEL_ID=

# Guild ID for instant slash command sync during development
# Remove or leave blank for global sync (takes up to 1 hour)
TEST_GUILD_ID=

# ── OPTIONAL — Rate Limits ────────────────────────────────────────────
OCR_COOLDOWN_SECONDS=10
TRANSLATE_COOLDOWN_SECONDS=5
COLORIZE_COOLDOWN_SECONDS=30

# ── OPTIONAL — File Limits ────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
