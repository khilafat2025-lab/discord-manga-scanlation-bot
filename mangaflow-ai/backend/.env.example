# MangaFlow AI - Environment Variables
# Copy this file to .env and fill in your values

# App
APP_NAME=MangaFlow AI
DEBUG=false
SECRET_KEY=your-super-secret-key-change-this-in-production
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql+asyncpg://mangaflow:your_password@localhost:5432/mangaflow
POSTGRES_PASSWORD=your_password

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Google OAuth (optional)
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# GitHub OAuth (optional)
# https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/auth/github/callback

# Cloudflare R2 (optional - uses local storage if not set)
# https://dash.cloudflare.com/
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=mangaflow-uploads
R2_PUBLIC_URL=

# AI APIs (at least one required for translation)
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Google Gemini: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# File Upload
MAX_FILE_SIZE_MB=2048
UPLOAD_DIR=/tmp/mangaflow/uploads
PROCESSED_DIR=/tmp/mangaflow/processed

# Processing
FREE_TIER_DAILY_PAGES=20
MAX_CONCURRENT_JOBS=5

# Security
RATE_LIMIT_PER_MINUTE=60
FILE_RETENTION_DAYS=30
